{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "catalyst-local",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  // nodejs_compat: rutas `runtime = "nodejs"` + node builtins en el Worker.
  // Los flags van SOLO aquí — wrangler 4.92+ los rechaza por CLI.
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
